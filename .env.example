# ===========================================
# Converso Environment Variables
# ===========================================

# DATABASE (Required)
# PostgreSQL connection string with pgvector extension (Neon recommended)
POSTGRES_URL="postgresql://username:password@host:5432/database?sslmode=require"

# AUTHENTICATION — Clerk (Required)
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# OPENAI (Required)
OPENAI_API_KEY="sk-..."

# STRIPE (Required for billing)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# APPLICATION (Required)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_EMAIL="your-email@example.com"

# UPSTASH REDIS (Required for production rate limiting)
# Get from: https://console.upstash.com → Create Database → REST API
# Falls back to in-memory rate limiting if not set (dev only)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# SENTRY (Required for production error monitoring)
# Get from: https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=""
SENTRY_ORG="cushlabsai"
SENTRY_PROJECT="cushlabs-chatbot-saas"
SENTRY_AUTH_TOKEN=""

# WHATSAPP (Optional — for WhatsApp channel support)
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""
